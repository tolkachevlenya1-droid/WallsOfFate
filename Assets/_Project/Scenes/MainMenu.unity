--- !u!114 &2014949153
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2014949151}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 707344d2e3523884e8bd8fb9f24dfb1a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  factText: {fileID: 742473884}
  facts:
  - "\u0412\u0435\u043B\u0438\u043A\u043E\u0435 \u041A\u043D\u044F\u0436\u0435\u0441\u0442\u0432\u043E
    \u041B\u0438\u0442\u043E\u0432\u0441\u043A\u043E\u0435 (\u0412\u041A\u041B) \u0432\u043E\u0437\u043D\u0438\u043A\u043B\u043E
    \u0432 1236 \u0433\u043E\u0434\u0443, \u0435\u0433\u043E \u043F\u0435\u0440\u0432\u043E\u0439
    \u0441\u0442\u043E\u043B\u0438\u0446\u0435\u0439 \u0431\u044B\u043B \u041D\u043E\u0432\u043E\u0433\u0440\u0443\u0434\u043E\u043A
    \u043D\u0430 \u0442\u0435\u0440\u0440\u0438\u0442\u043E\u0440\u0438\u0438 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0411\u0435\u043B\u0430\u0440\u0443\u0441\u0438, \u0430 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u043E
    \u043E\u043D\u043E \u0434\u043E 1795 \u0433\u043E\u0434\u0430."
  - "\u0412 1410 \u0433\u043E\u0434\u0443 \u0430\u0440\u043C\u0438\u0438 \u0412\u0435\u043B\u0438\u043A\u043E\u0433\u043E
    \u041A\u043D\u044F\u0436\u0435\u0441\u0442\u0432\u0430 \u041B\u0438\u0442\u043E\u0432\u0441\u043A\u043E\u0433\u043E
    \u0438 \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u0442\u0432\u0430 \u041F\u043E\u043B\u044C\u0441\u043A\u043E\u0433\u043E,
    \u043F\u043E\u0434 \u043A\u043E\u043C\u0430\u043D\u0434\u043E\u0432\u0430\u043D\u0438\u0435\u043C
    \u0432\u0435\u043B\u0438\u043A\u043E\u0433\u043E \u043A\u043D\u044F\u0437\u044F
    \u0412\u0438\u0442\u043E\u0432\u0442\u0430, \u043E\u0434\u0435\u0440\u0436\u0430\u043B\u0438
    \u043F\u043E\u0431\u0435\u0434\u0443 \u0432 \u0413\u0440\u044E\u043D\u0432\u0430\u043B\u044C\u0434\u0441\u043A\u043E\u0439
    \u0431\u0438\u0442\u0432\u0435 \u043F\u0440\u043E\u0442\u0438\u0432 \u0422\u0435\u0432\u0442\u043E\u043D\u0441\u043A\u043E\u0433\u043E
    \u043E\u0440\u0434\u0435\u043D\u0430. \u042D\u0442\u0430 \u0431\u0438\u0442\u0432\u0430
    \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F \u043E\u0434\u043D\u043E\u0439
    \u0438\u0437 \u043A\u0440\u0443\u043F\u043D\u0435\u0439\u0448\u0438\u0445 \u0432
    \u0421\u0440\u0435\u0434\u043D\u0435\u0432\u0435\u043A\u043E\u0432\u043E\u0439
    \u0415\u0432\u0440\u043E\u043F\u0435 \u0438 \u0438\u043C\u0435\u043B\u0430 \u0440\u0435\u0448\u0430\u044E\u0449\u0435\u0435
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435 \u0434\u043B\u044F \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0435\u043D\u0438\u044F
    \u043E\u0440\u0434\u0435\u043D\u0430 \u043A\u0440\u0435\u0441\u0442\u043E\u043D\u043E\u0441\u0446\u0435\u0432."
  - "\u0412 1529 \u0433\u043E\u0434\u0443 \u0431\u044B\u043B \u043F\u0440\u0438\u043D\u044F\u0442
    \u043F\u0435\u0440\u0432\u044B\u0439 \u0421\u0442\u0430\u0442\u0443\u0442 \u0412\u0435\u043B\u0438\u043A\u043E\u0433\u043E
    \u041A\u043D\u044F\u0436\u0435\u0441\u0442\u0432\u0430 \u041B\u0438\u0442\u043E\u0432\u0441\u043A\u043E\u0433\u043E,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u0442\u0430\u043B \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445 \u0432 \u0415\u0432\u0440\u043E\u043F\u0435
    \u0441\u0432\u043E\u0434\u043E\u0432 \u0437\u0430\u043A\u043E\u043D\u043E\u0432,
    \u043E\u0447\u0435\u043D\u044C \u043F\u043E\u0445\u043E\u0436\u0438\u043C \u043D\u0430
    \u043A\u043E\u043D\u0441\u0442\u0438\u0442\u0443\u0446\u0438\u044E \u0438 \u0440\u0435\u0433\u0443\u043B\u0438\u0440\u0443\u044E\u0449\u0438\u043C
    \u043F\u0440\u0430\u0432\u0430 \u0448\u043B\u044F\u0445\u0442\u044B, \u0437\u0435\u043C\u043B\u0435\u0432\u043B\u0430\u0434\u0435\u043B\u044C\u0446\u0435\u0432
    \u0438 \u043A\u0440\u0435\u0441\u0442\u044C\u044F\u043D."
  - "\u0412\u0435\u043B\u0438\u043A\u043E\u0435 \u041A\u043D\u044F\u0436\u0435\u0441\u0442\u0432\u043E
    \u041B\u0438\u0442\u043E\u0432\u0441\u043A\u043E\u0435 \u0438\u0437\u0431\u0435\u0436\u0430\u043B\u043E
    \u043C\u043E\u043D\u0433\u043E\u043B\u044C\u0441\u043A\u043E\u0433\u043E \u0438\u0433\u0430,
    \u0443\u0441\u0442\u0430\u043D\u0430\u0432\u043B\u0438\u0432\u0430\u044F \u0441\u0432\u044F\u0437\u0438
    \u0441 \u0442\u0430\u0442\u0430\u0440\u0430\u043C\u0438. \u0421 XIII \u0432\u0435\u043A\u0430
    \u0442\u0430\u0442\u0430\u0440\u044B \u043F\u0435\u0440\u0435\u0441\u0435\u043B\u044F\u043B\u0438\u0441\u044C
    \u0432 \u0412\u041A\u041B, \u043F\u043E\u043B\u0443\u0447\u0430\u044F \u0437\u0435\u043C\u043B\u0438
    \u0437\u0430 \u0432\u043E\u0435\u043D\u043D\u0443\u044E \u0441\u043B\u0443\u0436\u0431\u0443."
  - "\u0415\u0432\u0440\u0435\u0439\u0441\u043A\u0430\u044F \u043E\u0431\u0449\u0438\u043D\u0430
    \u0412\u0435\u043B\u0438\u043A\u043E\u0433\u043E \u041A\u043D\u044F\u0436\u0435\u0441\u0442\u0432\u0430
    \u041B\u0438\u0442\u043E\u0432\u0441\u043A\u043E\u0433\u043E \u0431\u044B\u043B\u0430
    \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u043A\u0440\u0443\u043F\u043D\u044B\u0445
    \u0432 \u0415\u0432\u0440\u043E\u043F\u0435. \u0412 \u043D\u0430\u0447\u0430\u043B\u0435
    XVI \u0432\u0435\u043A\u0430 \u0437\u0434\u0435\u0441\u044C \u0431\u044B\u043B\u043E
    \u0438\u0437\u0434\u0430\u043D\u043E \u043F\u0435\u0440\u0432\u043E\u0435 \u0435\u0432\u0440\u0435\u0439\u0441\u043A\u043E\u0435
    \u0438\u0437\u0434\u0430\u043D\u0438\u0435 \u0422\u043E\u0440\u044B."
  - "\u0412 1517 \u0433\u043E\u0434\u0443 \u0424\u0440\u0430\u043D\u0446\u0438\u0441\u043A
    \u0421\u043A\u043E\u0440\u0438\u043D\u0430 \u043D\u0430\u043F\u0435\u0447\u0430\u0442\u0430\u043B
    \u0432 \u041F\u0440\u0430\u0433\u0435 \xAB\u041F\u0441\u0430\u043B\u0442\u044B\u0440\u044C\xBB
    \u043D\u0430 \u0441\u0442\u0430\u0440\u043E\u0431\u0435\u043B\u043E\u0440\u0443\u0441\u0441\u043A\u043E\u043C
    \u044F\u0437\u044B\u043A\u0435, \u0441\u0442\u0430\u0432 \u043F\u0435\u0440\u0432\u044B\u043C
    \u043A\u043D\u0438\u0433\u043E\u043F\u0435\u0447\u0430\u0442\u043D\u0438\u043A\u043E\u043C
    \u0432 \u0412\u043E\u0441\u0442\u043E\u0447\u043D\u043E\u0439 \u0415\u0432\u0440\u043E\u043F\u0435."
  - "\u0420\u0430\u0434\u0437\u0438\u0432\u0438\u043B\u043B\u043E\u0432\u0441\u043A\u0430\u044F
    \u0411\u0438\u0431\u043B\u0438\u044F, \u0438\u0437\u0434\u0430\u043D\u043D\u0430\u044F
    \u0432 1563 \u0433\u043E\u0434\u0443, \u0431\u044B\u043B\u0430 \u043F\u0435\u0440\u0432\u043E\u0439
    \u043F\u043E\u043B\u043D\u043E\u0444\u043E\u0440\u043C\u0430\u0442\u043D\u043E\u0439
    \u0411\u0438\u0431\u043B\u0438\u0435\u0439, \u0438\u0437\u0434\u0430\u043D\u043D\u043E\u0439
    \u043D\u0430 \u0441\u0442\u0430\u0440\u043E\u0431\u0435\u043B\u043E\u0440\u0443\u0441\u0441\u043A\u043E\u043C
    \u044F\u0437\u044B\u043A\u0435.\r"
  - "\u0412 1610 \u0433\u043E\u0434\u0443 \u043F\u043E\u043B\u044C\u0441\u043A\u0438\u0435
    \u0438 \u043B\u0438\u0442\u043E\u0432\u0441\u043A\u0438\u0435 \u0432\u043E\u0439\u0441\u043A\u0430
    \u0432\u043E\u0448\u043B\u0438 \u0432 \u041C\u043E\u0441\u043A\u0432\u0443, \u0438
    \u0412\u043B\u0430\u0434\u0438\u0441\u043B\u0430\u0432 IV \u0431\u044B\u043B
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D \u0446\u0430\u0440\u0451\u043C \u041C\u043E\u0441\u043A\u043E\u0432\u0438\u0438,
    \u043D\u043E \u0435\u043C\u0443 \u0442\u0430\u043A \u0438 \u043D\u0435 \u0443\u0434\u0430\u043B\u043E\u0441\u044C
    \u0437\u0430\u0445\u0432\u0430\u0442\u0438\u0442\u044C \u0432\u043B\u0430\u0441\u0442\u044C
    \u0432 \u0420\u043E\u0441\u0441\u0438\u0438."
  - "\u0412 \u0412\u0435\u043B\u0438\u043A\u043E\u043C \u041A\u043D\u044F\u0436\u0435\u0441\u0442\u0432\u0435
    \u041B\u0438\u0442\u043E\u0432\u0441\u043A\u043E\u043C \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0430
    \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u0430\u044F \u0442\u043E\u043B\u0435\u0440\u0430\u043D\u0442\u043D\u043E\u0441\u0442\u044C,
    \u0438 \u043C\u0438\u0440\u043D\u043E \u0441\u043E\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0438
    \u043A\u0430\u0442\u043E\u043B\u0438\u043A\u0438, \u043F\u0440\u0430\u0432\u043E\u0441\u043B\u0430\u0432\u043D\u044B\u0435,
    \u043F\u0440\u043E\u0442\u0435\u0441\u0442\u0430\u043D\u0442\u044B, \u0438\u0443\u0434\u0435\u0438
    \u0438 \u043C\u0443\u0441\u0443\u043B\u044C\u043C\u0430\u043D\u0435.\r\n"
  - "\u0412 1610 \u0433\u043E\u0434\u0443 \u043F\u043E\u043B\u044C\u0441\u043A\u0438\u0435
    \u0438 \u043B\u0438\u0442\u043E\u0432\u0441\u043A\u0438\u0435 \u0432\u043E\u0439\u0441\u043A\u0430
    \u0432\u043E\u0448\u043B\u0438 \u0432 \u041C\u043E\u0441\u043A\u0432\u0443, \u0438
    \u0412\u043B\u0430\u0434\u0438\u0441\u043B\u0430\u0432 IV \u0431\u044B\u043B
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D \u0446\u0430\u0440\u0451\u043C \u041C\u043E\u0441\u043A\u043E\u0432\u0438\u0438,
    \u043D\u043E \u0435\u043C\u0443 \u0442\u0430\u043A \u0438 \u043D\u0435 \u0443\u0434\u0430\u043B\u043E\u0441\u044C
    \u0437\u0430\u0445\u0432\u0430\u0442\u0438\u0442\u044C \u0432\u043B\u0430\u0441\u0442\u044C
    \u0432 \u0420\u043E\u0441\u0441\u0438\u0438."
  - "10\u201315% \u043D\u0430\u0441\u0435\u043B\u0435\u043D\u0438\u044F \u0412\u0435\u043B\u0438\u043A\u043E\u0433\u043E
    \u041A\u043D\u044F\u0436\u0435\u0441\u0442\u0432\u0430 \u041B\u0438\u0442\u043E\u0432\u0441\u043A\u043E\u0433\u043E
    \u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0430\u043B\u0438 \u043A
    \u0434\u0432\u043E\u0440\u044F\u043D\u0441\u043A\u043E\u043C\u0443 \u0441\u043E\u0441\u043B\u043E\u0432\u0438\u044E
    (\u0448\u043B\u044F\u0445\u0442\u0435) \u0438 \u043F\u0440\u0435\u0438\u043C\u0443\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E
    \u043F\u043E\u043B\u0443\u0447\u0430\u043B\u0438 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0437\u0430 \u0433\u0440\u0430\u043D\u0438\u0446\u0435\u0439."
  - "\u0423 \u0412\u0435\u043B\u0438\u043A\u043E\u0433\u043E \u041A\u043D\u044F\u0436\u0435\u0441\u0442\u0432\u0430
    \u041B\u0438\u0442\u043E\u0432\u0441\u043A\u043E\u0433\u043E \u0432 \u0441\u043E\u0441\u0442\u0430\u0432\u0435
    \u0420\u0435\u0447\u0438 \u041F\u043E\u0441\u043F\u043E\u043B\u0438\u0442\u043E\u0439
    \u0431\u044B\u043B\u0438 \u0441\u0432\u043E\u0438 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435
    \u0437\u0430\u043A\u043E\u043D\u044B, \u0430\u0440\u043C\u0438\u044F, \u043A\u0430\u0437\u043D\u0430
    \u0438 \u0441\u0438\u0441\u0442\u0435\u043C\u0430 \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F,
    \u0447\u0442\u043E \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u0432\u0430\u043B\u043E
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0451\u043D\u043D\u0443\u044E \u0430\u0432\u0442\u043E\u043D\u043E\u043C\u0438\u044E
    \u0432 \u0440\u0430\u043C\u043A\u0430\u0445 \u0444\u0435\u0434\u0435\u0440\u0430\u0442\u0438\u0432\u043D\u043E\u0433\u043E
    \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0430."
  - "\u0412 1791 \u0433\u043E\u0434\u0443 \u0432 \u0420\u0435\u0447\u0438 \u041F\u043E\u0441\u043F\u043E\u043B\u0438\u0442\u043E\u0439
    (\u0432\u043A\u043B\u044E\u0447\u0430\u0432\u0448\u0435\u0439 \u0412\u0435\u043B\u0438\u043A\u043E\u0435
    \u041A\u043D\u044F\u0436\u0435\u0441\u0442\u0432\u043E \u041B\u0438\u0442\u043E\u0432\u0441\u043A\u043E\u0435
    \u0438 \u041F\u043E\u043B\u044C\u0448\u0443) \u0431\u044B\u043B\u0430 \u043F\u0440\u0438\u043D\u044F\u0442\u0430
    \u041A\u043E\u043D\u0441\u0442\u0438\u0442\u0443\u0446\u0438\u044F 3 \u043C\u0430\u044F,
    \u043F\u0435\u0440\u0432\u0430\u044F \u0432 \u0415\u0432\u0440\u043E\u043F\u0435
    \u0438 \u0432\u0442\u043E\u0440\u0430\u044F \u0432 \u043C\u0438\u0440\u0435 (\u043F\u043E\u0441\u043B\u0435
    \u0430\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u043A\u043E\u0439).\r"
  - "\u0412\u0435\u043B\u0438\u043A\u043E\u0435 \u041A\u043D\u044F\u0436\u0435\u0441\u0442\u0432\u043E
    \u041B\u0438\u0442\u043E\u0432\u0441\u043A\u043E\u0435, \u0432\u043A\u043B\u044E\u0447\u0430\u0432\u0448\u0435\u0435
    \u0442\u0435\u0440\u0440\u0438\u0442\u043E\u0440\u0438\u044E \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0411\u0435\u043B\u0430\u0440\u0443\u0441\u0438, \u0431\u044B\u043B\u043E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E
    \u043A\u0430\u043A \xAB\u0441\u0442\u0440\u0430\u043D\u0430 \u0437\u0430\u043C\u043A\u043E\u0432\xBB.
    \u041A\u0430\u043C\u0435\u043D\u043D\u044B\u0435 \u0437\u0430\u043C\u043A\u0438,
    \u0442\u0430\u043A\u0438\u0435 \u043A\u0430\u043A \u041C\u0438\u0440\u0441\u043A\u0438\u0439
    \u0438 \u041D\u0435\u0441\u0432\u0438\u0436\u0441\u043A\u0438\u0439, \u0431\u044B\u043B\u0438
    \u043A\u0440\u0435\u043F\u043E\u0441\u0442\u044F\u043C\u0438 \u0438 \u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0446\u0438\u044F\u043C\u0438,
    \u0430 \u043D\u044B\u043D\u0435 \u0432\u0445\u043E\u0434\u044F\u0442 \u0432 \u0441\u043F\u0438\u0441\u043E\u043A
    \u042E\u041D\u0415\u0421\u041A\u041E.\r\n"
  - "\u0421\u043B\u0443\u0446\u043A\u0438\u0435 \u043F\u043E\u044F\u0441\u0430 XVIII
    \u0432\u0435\u043A\u0430, \u0448\u0451\u043B\u043A\u043E\u0432\u044B\u0435 \u0441
    \u0437\u043E\u043B\u043E\u0442\u044B\u043C\u0438 \u0438 \u0441\u0435\u0440\u0435\u0431\u0440\u044F\u043D\u044B\u043C\u0438
    \u0443\u0437\u043E\u0440\u0430\u043C\u0438, \u0442\u043A\u0430\u043B\u0438\u0441\u044C
    \u043D\u0430 \u0421\u043B\u0443\u0446\u043A\u043E\u0439 \u043C\u0430\u043D\u0443\u0444\u0430\u043A\u0442\u0443\u0440\u0435
    \u0412\u0435\u043B\u0438\u043A\u043E\u0433\u043E \u041A\u043D\u044F\u0436\u0435\u0441\u0442\u0432\u0430
    \u041B\u0438\u0442\u043E\u0432\u0441\u043A\u043E\u0433\u043E. \u0421\u0438\u043C\u0432\u043E\u043B
    \u0448\u043B\u044F\u0445\u0435\u0442\u0441\u043A\u043E\u0433\u043E \u0441\u0442\u0430\u0442\u0443\u0441\u0430,
    \u043E\u043D\u0438 \u0441\u043E\u0447\u0435\u0442\u0430\u043B\u0438 \u0432\u043E\u0441\u0442\u043E\u0447\u043D\u044B\u0435
    \u0438 \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u0438\u0435 \u043C\u043E\u0442\u0438\u0432\u044B
    \u0438 \u043D\u044B\u043D\u0435 \u2014 \u043A\u0443\u043B\u044C\u0442\u0443\u0440\u043D\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0411\u0435\u043B\u0430\u0440\u0443\u0441\u0438."
  - "\u0421\u043B\u0443\u0446\u043A\u0438\u0435 \u043F\u043E\u044F\u0441\u0430 XVIII
    \u0432\u0435\u043A\u0430, \u0448\u0451\u043B\u043A\u043E\u0432\u044B\u0435 \u0441
    \u0437\u043E\u043B\u043E\u0442\u044B\u043C\u0438 \u0438 \u0441\u0435\u0440\u0435\u0431\u0440\u044F\u043D\u044B\u043C\u0438
    \u0443\u0437\u043E\u0440\u0430\u043C\u0438, \u0442\u043A\u0430\u043B\u0438\u0441\u044C
    \u043D\u0430 \u0421\u043B\u0443\u0446\u043A\u043E\u0439 \u043C\u0430\u043D\u0443\u0444\u0430\u043A\u0442\u0443\u0440\u0435
    \u0412\u0435\u043B\u0438\u043A\u043E\u0433\u043E \u041A\u043D\u044F\u0436\u0435\u0441\u0442\u0432\u0430
    \u041B\u0438\u0442\u043E\u0432\u0441\u043A\u043E\u0433\u043E. \u0421\u0438\u043C\u0432\u043E\u043B
    \u0448\u043B\u044F\u0445\u0435\u0442\u0441\u043A\u043E\u0433\u043E \u0441\u0442\u0430\u0442\u0443\u0441\u0430,
    \u043E\u043D\u0438 \u0441\u043E\u0447\u0435\u0442\u0430\u043B\u0438 \u0432\u043E\u0441\u0442\u043E\u0447\u043D\u044B\u0435
    \u0438 \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u0438\u0435 \u043C\u043E\u0442\u0438\u0432\u044B
    \u0438 \u043D\u044B\u043D\u0435 \u2014 \u043A\u0443\u043B\u044C\u0442\u0443\u0440\u043D\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0411\u0435\u043B\u0430\u0440\u0443\u0441\u0438."
  - "\u0421\u0442\u0430\u0440\u043E\u0431\u0435\u043B\u043E\u0440\u0443\u0441\u0441\u043A\u0438\u0439
    \u044F\u0437\u044B\u043A, \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0439
    \u044F\u0437\u044B\u043A \u0412\u0435\u043B\u0438\u043A\u043E\u0433\u043E \u041A\u043D\u044F\u0436\u0435\u0441\u0442\u0432\u0430
    \u041B\u0438\u0442\u043E\u0432\u0441\u043A\u043E\u0433\u043E, \u043C\u043E\u0433
    \u0431\u044B\u0442\u044C \u0437\u0430\u043F\u0438\u0441\u0430\u043D \u043A\u0438\u0440\u0438\u043B\u043B\u0438\u0446\u0435\u0439,
    \u043B\u0430\u0442\u0438\u043D\u0438\u0446\u0435\u0439 \u0438 \u0430\u0440\u0430\u0431\u0441\u043A\u043E\u0439
    \u0432\u044F\u0437\u044C\u044E."
