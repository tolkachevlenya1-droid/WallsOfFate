  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0412 \u0437\u0435\u043B\u0451\u043D\u044B\u0445 \u043F\u0440\u0435\u0434\u0433\u043E\u0440\u044C\u044F\u0445
    \u0415\u0432\u0440\u043E\u043F\u044B, \u0433\u0434\u0435 \u043A\u0430\u0440\u0430\u0432\u0430\u043D\u044B
    \u0441\u043F\u0435\u0448\u0438\u043B\u0438 \u043A \u0448\u0443\u043C\u043D\u044B\u043C
    \u044F\u0440\u043C\u0430\u0440\u043A\u0430\u043C, \u0432\u043E\u0437\u043D\u043E\u0441\u0438\u043B\u043E\u0441\u044C
    \u0432\u0435\u043B\u0438\u043A\u043E\u0435 \u043A\u043D\u044F\u0436\u0435\u0441\u0442\u0432\u043E.
    \u041E\u0434\u043D\u0430\u0436\u0434\u044B \u043F\u043E \u0443\u0442\u0440\u0435\u043D\u043D\u0435\u0439
    \u0440\u043E\u0441\u0435 \u0437\u0430 \u0442\u0440\u0435\u0437\u0443\u0431\u0446\u0435\u043C
    \u0435\u0433\u043E \u0444\u043B\u0430\u0433\u0430 \u043F\u043E\u043A\u0430\u0437\u0430\u043B\u0438\u0441\u044C
    \u0437\u043D\u0430\u043C\u0435\u043D\u0430 \u0432\u0440\u0430\u0433\u0430. \u041C\u0430\u0433\u043D\u0430\u0442
    \u0441 \u043E\u0442\u0440\u044F\u0434\u043E\u043C \u0437\u0430\u0449\u0438\u0442\u043D\u0438\u043A\u043E\u0432
    \u0443\u043A\u0440\u0435\u043F\u0438\u043B\u0441\u044F \u0432 \u0434\u0440\u0435\u0432\u043D\u0435\u0439
    \u043A\u0440\u0435\u043F\u043E\u0441\u0442\u0438 \u0438 \u043D\u0430\u0447\u0430\u043B
    \u0434\u043E\u043B\u0433\u0443\u044E \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u043A\u0443
    \u043A \u043E\u0441\u0430\u0434\u0435."
